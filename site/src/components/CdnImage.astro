---
import { IMAGE_CDN } from '../consts';

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
}

const { src, alt, width, height, class: className } = Astro.props;

// 完整 URL 直接用，否则拼接 R2 CDN
const fullSrc = src.startsWith('http') ? src : `${IMAGE_CDN}/${src}`;
---

<img
  src={fullSrc}
  alt={alt}
  width={width}
  height={height}
  loading="lazy"
  decoding="async"
  class={className}
/>
