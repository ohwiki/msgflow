<div id="btt-btn-container" class="fixed end-4 bottom-8 z-50 translate-y-14 opacity-0 transition duration-500">
  <button data-button="back-to-top" class="group relative bg-background px-2 py-1 size-14 rounded-full shadow-xl">
    <svg class="inline-block rotate-90 size-6" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    <span class="sr-only">Back To Top</span>
  </button>
</div>

<script is:inline>
(function(){
  var container = document.getElementById('btt-btn-container');
  var btn = container?.querySelector('[data-button="back-to-top"]');
  window.addEventListener('scroll', function() {
    var show = window.scrollY > window.innerHeight * 0.3;
    container.style.opacity = show ? '1' : '0';
    container.style.transform = show ? 'translateY(0)' : 'translateY(3.5rem)';
  }, { passive: true });
  btn?.addEventListener('click', function() { window.scrollTo({ top: 0, behavior: 'smooth' }); });
})();
</script>
