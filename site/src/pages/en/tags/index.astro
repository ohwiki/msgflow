---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Tag from '../../../components/Tag.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles-en', ({ data }) => !data.draft);
const tagMap = new Map<string, number>();
articles.forEach((a) => a.data.tags.forEach((t) => tagMap.set(t, (tagMap.get(t) || 0) + 1)));
const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags">
  <Breadcrumb items={[{ label: 'Tags' }]} />
  <section class="mx-auto max-w-app px-4 pb-6">
    <h1 class="text-2xl font-semibold tracking-wide mb-8">Tags</h1>
    <ul class="flex flex-wrap gap-2">
      {tags.map(([name]) => <Tag name={name} size="lg" basePath="/en/tags" />)}
    </ul>
    {tags.length === 0 && <p class="py-8 opacity-60">No tags yet</p>}
  </section>
</BaseLayout>
