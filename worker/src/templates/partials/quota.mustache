<div class="max-w-2xl mx-auto flex flex-col gap-3">
  <div class="flex items-center justify-between">
    <h1 class="text-lg font-semibold">💰 EasyClaude 额度查询</h1>
    {{#hasKeys}}
    <button class="btn btn-ghost btn-sm gap-1" hx-post="/api/quota/check" hx-vals='{"mode":"saved"}' hx-target="#quota-result" hx-indicator="#quota-loading">
      🔄 刷新 ({{keyCount}})
    </button>
    {{/hasKeys}}
  </div>

  <div class="collapse collapse-arrow bg-base-100 shadow">
    <input type="checkbox" {{^hasKeys}}checked{{/hasKeys}} />
    <div class="collapse-title text-sm font-medium py-2 min-h-0">手动查询（临时）</div>
    <div class="collapse-content">
      <form hx-post="/api/quota/check" hx-target="#quota-result" hx-indicator="#quota-loading" class="join w-full">
        <input type="hidden" name="mode" value="manual"/>
        <input type="text" name="api_key" class="input input-bordered input-sm join-item flex-1 font-mono" placeholder="sk-xxxxxxxx" autocomplete="off"/>
        <button type="submit" class="btn btn-primary btn-sm join-item">查询</button>
      </form>
    </div>
  </div>

  {{^hasKeys}}
  <div class="alert alert-info text-sm py-2">
    💡 尚未配置 key，请先在 <a href="/settings" class="link font-medium">设置</a> 中添加。
  </div>
  {{/hasKeys}}

  <div id="quota-loading" class="htmx-indicator flex justify-center py-4">
    <span class="loading loading-spinner loading-md"></span>
  </div>
  <div id="quota-result" hx-swap="innerHTML">
    {{#hasKeys}}
    <div hx-post="/api/quota/check" hx-vals='{"mode":"saved"}' hx-target="#quota-result" hx-indicator="#quota-loading" hx-trigger="load"></div>
    {{/hasKeys}}
  </div>
</div>
