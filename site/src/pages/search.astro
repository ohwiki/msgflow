---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { t, getLocaleFromUrl } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
---

<BaseLayout title={t('nav.search', locale)}>
  <Breadcrumb items={[{ label: t('nav.search', locale) }]} />
  <section class="mx-auto max-w-app px-4 pb-6">
    <h1 class="text-2xl font-semibold tracking-wide mb-8">{t('nav.search', locale)}</h1>
    <div id="search-container">
      <input
        id="search-input"
        type="text"
        placeholder={t('search.placeholder', locale)}
        class="w-full rounded-lg border border-border bg-background px-4 py-3 text-foreground placeholder:opacity-50 focus:border-accent focus:outline-none"
      />
      <div id="search-results" class="mt-6"></div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
(async function() {
  await import('/pagefind/pagefind-ui.js');
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');
  let pagefind;

  try {
    pagefind = await import('/pagefind/pagefind.js');
    await pagefind.init();
  } catch (e) {
    results.innerHTML = '<p class="opacity-60">搜索索引未就绪，请先运行 build。</p>';
    return;
  }

  input.addEventListener('input', async function() {
    const query = input.value.trim();
    if (!query) { results.innerHTML = ''; return; }
    const search = await pagefind.search(query);
    if (search.results.length === 0) {
      results.innerHTML = '<p class="opacity-60">未找到结果</p>';
      return;
    }
    const items = await Promise.all(search.results.slice(0, 10).map(r => r.data()));
    results.innerHTML = items.map(item =>
      '<article class="mb-6 pb-6 border-b border-border last:border-b-0">' +
        '<a href="' + item.url + '" class="text-lg font-medium text-accent decoration-dashed hover:underline underline-offset-4">' + item.meta.title + '</a>' +
        '<p class="mt-1 text-sm opacity-70">' + item.excerpt + '</p>' +
      '</article>'
    ).join('');
  });
})();
</script>
