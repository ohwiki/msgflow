---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import ShareLinks from '../../../components/ShareLinks.astro';
import CodeCopy from '../../../components/islands/CodeCopy.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles-en');
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
---

<BaseLayout title={article.data.title} description={article.data.summary} type="article" publishedTime={article.data.date} tags={article.data.tags}>
  <Breadcrumb items={[{ label: 'Posts', href: '/en/articles' }, { label: article.data.title }]} />

  <article class="mx-auto max-w-app px-4 pb-12">
    <header class="mb-8">
      <h1 class="text-3xl font-bold leading-[1.2]">{article.data.title}</h1>
      <div class="mt-3 flex items-center gap-x-2 opacity-80 text-sm">
        {article.data.author && <span>{article.data.author}</span>}
        <time datetime={article.data.date.toISOString().slice(0, 10)}>
          {article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
        </time>
      </div>
      {article.data.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {article.data.tags.map((tag) => (
            <a href={`/en/tags/${tag}`} class="text-sm text-accent decoration-dashed hover:underline">#{tag}</a>
          ))}
        </div>
      )}
    </header>

    <div class="app-prose max-w-none">
      <Content />
    </div>

    <footer class="mt-12 pt-6 border-t border-border">
      <ShareLinks url={Astro.url.href} title={article.data.title} />
      <div class="mt-6 flex gap-4">
        <a href="/en/articles" class="hover:text-accent">← Back to list</a>
        {article.data.source_url && <a href={article.data.source_url} target="_blank" rel="noopener" class="hover:text-accent">View source ↗</a>}
      </div>
    </footer>
  </article>

  <CodeCopy />
</BaseLayout>
