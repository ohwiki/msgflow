---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/islands/BackToTop.astro';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  tags?: string[];
}

const { title, description = 'msgflow - 内容聚合与展示', type = 'website', publishedTime, tags = [] } = Astro.props;
const canonicalUrl = Astro.url.href;
---

<!DOCTYPE html>
<html lang="zh" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <link rel="canonical" href={canonicalUrl} />
  <title>{title} - msgflow</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalUrl} />
  {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="alternate" type="application/rss+xml" title="msgflow RSS" href="/feed.xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <script is:inline>
    (function(){var t=localStorage.getItem('theme')||(window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');document.documentElement.setAttribute('data-theme',t)})();
  </script>
</head>
<body class="flex min-h-svh flex-col bg-background font-mono text-foreground">
  <Header />
  <main id="main-content" class="flex-1">
    <slot />
  </main>
  <Footer />
  <BackToTop />
</body>
</html>
