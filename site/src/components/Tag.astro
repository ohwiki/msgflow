---
interface Props {
  name: string;
  size?: 'sm' | 'lg';
  basePath?: string;
}

const { name, size = 'sm', basePath = '/tags' } = Astro.props;
---

<li class:list={['group inline-block group-hover:cursor-pointer', size === 'sm' ? 'my-1 underline-offset-4' : 'mx-1 my-3 underline-offset-8']}>
  <a
    href={`${basePath}/${name}`}
    class:list={['relative pe-2 underline decoration-dashed group-hover:-top-0.5 group-hover:text-accent focus-visible:p-1 focus-visible:no-underline', size === 'sm' ? 'text-sm' : 'text-lg']}
  >
    <svg class:list={['inline-block opacity-80', size === 'sm' ? '-me-3.5 size-4' : '-me-5 size-6']} xmlns="http://www.w3.org/2000/svg" width={size === 'sm' ? '16' : '24'} height={size === 'sm' ? '16' : '24'} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 9l14 0"/><path d="M5 15l14 0"/><path d="M11 4l-4 16"/><path d="M17 4l-4 16"/></svg>
    &nbsp;<span>{name}</span>
  </a>
</li>
