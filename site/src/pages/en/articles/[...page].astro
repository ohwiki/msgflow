---
import ArticleListPage from '../../../templates/ArticleListPage.astro';
import { getCollection } from 'astro:content';
import { POSTS_PER_PAGE } from '../../../consts';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const articles = (await getCollection('articles-en', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return paginate(articles, { pageSize: POSTS_PER_PAGE });
};

const { page } = Astro.props;
---

<ArticleListPage locale="en" page={page} />
