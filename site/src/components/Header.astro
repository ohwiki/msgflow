---
import { t, getLocaleFromUrl } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const prefix = locale === 'zh' ? '' : `/${locale}`;
const navItems = [
  { href: `${prefix}/articles`, label: t('nav.posts', locale) },
  { href: `${prefix}/tags`, label: t('nav.tags', locale) },
  { href: `${prefix}/archives`, label: t('nav.archives', locale) },
];
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (currentPath === href || currentPath === href + '/') return true;
  const hrefParts = href.split('/').filter(Boolean);
  const curParts = currentPath.split('/').filter(Boolean);
  // 跳过语言前缀比较实际路径段
  const hrefSeg = hrefParts[hrefParts.length - 1];
  const curSeg = locale === 'zh' ? curParts[0] : curParts[1];
  return hrefSeg && hrefSeg === curSeg;
}
---

<header>
  <a id="skip-to-content" href="#main-content" class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4">
    {t('ui.skipToContent', locale)}
  </a>
  <div class="mx-auto flex max-w-app flex-col items-center justify-between">
    <div class="relative flex w-full items-baseline justify-between bg-background p-4 sm:items-center sm:py-6">
      <a href="/" class="absolute py-1 text-xl leading-8 font-semibold whitespace-nowrap sm:static sm:my-auto sm:text-2xl sm:leading-none">
        📄 msgflow
      </a>
      <nav class="flex w-full flex-col items-center sm:ms-2 sm:flex-row sm:justify-end sm:space-x-4 sm:py-0">
        <button id="menu-btn" class="focus-outline self-end p-2 sm:hidden" aria-label="Open Menu" aria-expanded="false" aria-controls="menu-items">
          <svg id="close-icon" class="hidden size-6" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
          <svg id="menu-icon" class="size-6" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>
        <ul id="menu-items" class="mt-4 hidden sm:flex w-44 grid-cols-2 gap-2 sm:mt-0 sm:w-auto sm:gap-x-5 sm:items-center [&>li>a]:block [&>li>a]:px-4 [&>li>a]:py-3 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:hover:text-accent sm:[&>li>a]:px-2 sm:[&>li>a]:py-1">
          {navItems.map(({ href, label }) => (
            <li class="col-span-2">
              <a href={href} class={isActive(href) ? 'active-nav' : ''}>{label}</a>
            </li>
          ))}
          <li class="col-span-1 flex items-center justify-center">
            <a href={`${prefix}/search`} class="focus-outline flex p-3 sm:p-1" aria-label={t('nav.search', locale)} title={t('nav.search', locale)}>
              <svg class="size-6" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              <span class="sr-only">{t('nav.search', locale)}</span>
            </a>
          </li>
          <li class="col-span-1 flex items-center justify-center">
            <a href="/feed.xml" class="focus-outline flex p-3 sm:p-1" aria-label="RSS" title="RSS Feed">
              <svg class="size-6" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
              <span class="sr-only">RSS</span>
            </a>
          </li>
          <li class="col-span-1 flex items-center justify-center">
            <button id="lang-btn" class="focus-outline p-3 sm:p-1 text-sm font-medium hover:text-accent" title="切换语言">
              中/EN
            </button>
          </li>
          <li class="col-span-1 flex items-center justify-center">
            <button id="theme-btn" class="focus-outline p-3 sm:p-1 hover:text-accent" title="切换主题" aria-label="切换主题">
              <svg id="moon-svg" class="size-6" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
              <svg id="sun-svg" class="size-6" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            </button>
          </li>
        </ul>
      </nav>
    </div>
  </div>
  <hr class="border-border" />
</header>

<script is:inline>
(function(){
  const btn = document.getElementById('menu-btn');
  const items = document.getElementById('menu-items');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  btn?.addEventListener('click', () => {
    const open = items.classList.toggle('hidden');
    menuIcon.classList.toggle('hidden', !open);
    closeIcon.classList.toggle('hidden', open);
    btn.setAttribute('aria-expanded', String(!open));
  });

  const themeBtn = document.getElementById('theme-btn');
  themeBtn?.addEventListener('click', () => {
    const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  const langBtn = document.getElementById('lang-btn');
  langBtn?.addEventListener('click', () => {
    const path = window.location.pathname;
    if (path.startsWith('/en/') || path === '/en') {
      window.location.pathname = path.replace(/^\/en/, '') || '/';
    } else {
      window.location.pathname = '/en' + path;
    }
  });
})();
</script>
