---
// ThemeToggle 的按钮已内嵌在 Header.astro 中
// 这个组件只提供初始化脚本（防止闪烁）
---

<script is:inline>
(function(){
  const t = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  document.documentElement.setAttribute('data-theme', t);
})();
</script>
