---
interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;
const encoded = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);

const links = [
  { name: 'Twitter', href: `https://twitter.com/intent/tweet?url=${encoded}&text=${encodedTitle}`, icon: 'M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z' },
  { name: 'Facebook', href: `https://www.facebook.com/sharer.php?u=${encoded}`, icon: 'M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z' },
  { name: 'LinkedIn', href: `https://www.linkedin.com/shareArticle?mini=true&url=${encoded}&title=${encodedTitle}`, icon: 'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z|R2,9,4,12|C4,4,2' },
  { name: 'Telegram', href: `https://t.me/share/url?url=${encoded}&text=${encodedTitle}`, icon: 'L22,2,11,13|P22 2 15 22 11 13 2 9 22 2' },
  { name: 'WhatsApp', href: `https://wa.me/?text=${encodedTitle}%20${encoded}`, icon: 'M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z' },
];
---

<div class="mt-8 flex flex-col items-center gap-2 sm:flex-row sm:items-center">
  <span class="text-sm italic opacity-70">Share this post:</span>
  <div class="flex gap-1">
    {links.map(({ name, href, icon }) => (
      <a href={href} target="_blank" rel="noopener noreferrer" title={`Share on ${name}`} class="p-2 opacity-70 hover:opacity-100 hover:text-accent transition-opacity">
        {name === 'LinkedIn' ? (
          <svg class="size-5" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        ) : name === 'Telegram' ? (
          <svg class="size-5" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        ) : (
          <svg class="size-5" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={icon}/></svg>
        )}
        <span class="sr-only">Share on {name}</span>
      </a>
    ))}
  </div>
</div>
