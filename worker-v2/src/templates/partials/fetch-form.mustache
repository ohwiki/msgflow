<div class="card bg-base-100 shadow">
  <div class="card-body">
    <h2 class="card-title">抓取文章</h2>
    <p class="text-sm text-base-content/60">输入 URL，支持微信公众号、飞书文档、Twitter/X、RSS、普通网页</p>
    <form hx-post="/api/fetch" hx-target="#fetch-result" hx-indicator="#fetch-loading" class="mt-4 space-y-4">
      <div class="join w-full">
        <input type="url" name="url" placeholder="https://mp.weixin.qq.com/s/..." class="input input-bordered join-item flex-1" required/>
        <button type="submit" class="btn btn-primary join-item">抓取</button>
      </div>
      <div>
        <label class="label"><span class="label-text font-medium">分类标签</span></label>
        <div class="flex flex-wrap gap-2" id="tag-options">
          <label class="cursor-pointer"><input type="checkbox" name="tags" value="AI" class="checkbox checkbox-xs checkbox-primary"/> <span class="text-sm">AI</span></label>
          <label class="cursor-pointer"><input type="checkbox" name="tags" value="Cloudflare" class="checkbox checkbox-xs checkbox-primary"/> <span class="text-sm">Cloudflare</span></label>
          <label class="cursor-pointer"><input type="checkbox" name="tags" value="教程" class="checkbox checkbox-xs checkbox-primary"/> <span class="text-sm">教程</span></label>
          <label class="cursor-pointer"><input type="checkbox" name="tags" value="工具" class="checkbox checkbox-xs checkbox-primary"/> <span class="text-sm">工具</span></label>
          <label class="cursor-pointer"><input type="checkbox" name="tags" value="前端" class="checkbox checkbox-xs checkbox-primary"/> <span class="text-sm">前端</span></label>
          <label class="cursor-pointer"><input type="checkbox" name="tags" value="后端" class="checkbox checkbox-xs checkbox-primary"/> <span class="text-sm">后端</span></label>
          <label class="cursor-pointer"><input type="checkbox" name="tags" value="产品" class="checkbox checkbox-xs checkbox-primary"/> <span class="text-sm">产品</span></label>
          <label class="cursor-pointer"><input type="checkbox" name="tags" value="效率" class="checkbox checkbox-xs checkbox-primary"/> <span class="text-sm">效率</span></label>
        </div>
        <input type="text" name="custom_tags" placeholder="自定义标签（逗号分隔）" class="input input-bordered input-sm w-full mt-2"/>
      </div>
    </form>
    <div id="fetch-loading" class="htmx-indicator mt-4"><span class="loading loading-spinner loading-sm"></span> 正在抓取...</div>
    <div id="fetch-result" class="mt-4"></div>
  </div>
</div>
