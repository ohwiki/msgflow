---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="所有文章">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold mb-6">所有文章</h1>

    <div class="overflow-x-auto bg-base-100 rounded-box shadow">
      <table class="table">
        <thead>
          <tr>
            <th>标题</th>
            <th>来源</th>
            <th>日期</th>
          </tr>
        </thead>
        <tbody>
          {articles.map((article) => (
            <tr class="hover">
              <td>
                <a href={`/articles/${article.slug}`} class="link link-hover font-medium">{article.data.title}</a>
              </td>
              <td><span class="badge badge-ghost badge-sm">{article.data.source_type ?? 'web'}</span></td>
              <td class="text-sm text-base-content/60">{article.data.date.toLocaleDateString('zh-CN')}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>
