<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold mb-6">设置</h1>
  {{#success}}<div class="alert alert-success text-sm mb-4">✓ {{success}}</div>{{/success}}
  {{#error}}<div class="alert alert-error text-sm mb-4">✗ {{error}}</div>{{/error}}

  <div class="card bg-base-100 shadow mb-6">
    <div class="card-body gap-0">
      <h2 class="card-title text-lg mb-4">GitHub 集成</h2>
      <form method="POST" action="/settings" class="space-y-4">
        <input type="hidden" name="action" value="save_github"/>
        <label class="form-control w-full">
          <div class="label"><span class="label-text font-medium">GitHub Token</span></div>
          <input type="password" name="github_token" value="{{github_token_masked}}" class="input input-bordered w-full" placeholder="ghp_..."/>
          <div class="label"><span class="label-text-alt text-base-content/50">需要 repo + workflow 权限</span></div>
        </label>
        <label class="form-control w-full">
          <div class="label"><span class="label-text font-medium">GitHub Repo</span></div>
          <input type="text" name="github_repo" value="{{github_repo}}" class="input input-bordered w-full" placeholder="owner/repo"/>
        </label>
        <div class="pt-2">
          <button type="submit" class="btn btn-primary w-full">保存 GitHub 配置</button>
        </div>
      </form>
    </div>
  </div>

  <div class="card bg-base-100 shadow mb-6">
    <div class="card-body gap-0">
      <h2 class="card-title text-lg mb-4">第三方 API（微信抓取 fallback）</h2>
      <form method="POST" action="/settings" class="space-y-4">
        <input type="hidden" name="action" value="save_api_keys"/>
        <label class="form-control w-full">
          <div class="label"><span class="label-text font-medium">Tavily API Key</span></div>
          <div class="join w-full">
            <input type="password" name="tavily_api_key" id="tavily_input" value="{{tavily_key_value}}" class="input input-bordered join-item w-full" placeholder="tvly-..."/>
            <button type="button" class="btn join-item" onclick="const i=document.getElementById('tavily_input');i.type=i.type==='password'?'text':'password'">👁</button>
            <button type="button" class="btn join-item" onclick="navigator.clipboard.writeText(document.getElementById('tavily_input').value);this.textContent='✓';setTimeout(()=>this.textContent='📋',1000)">📋</button>
          </div>
          <div class="label"><span class="label-text-alt text-base-content/50">用于穿透微信验证页，优先使用</span></div>
        </label>
        <label class="form-control w-full">
          <div class="label"><span class="label-text font-medium">Exa API Key</span></div>
          <div class="join w-full">
            <input type="password" name="exa_api_key" id="exa_input" value="{{exa_key_value}}" class="input input-bordered join-item w-full" placeholder="exa-..."/>
            <button type="button" class="btn join-item" onclick="const i=document.getElementById('exa_input');i.type=i.type==='password'?'text':'password'">👁</button>
            <button type="button" class="btn join-item" onclick="navigator.clipboard.writeText(document.getElementById('exa_input').value);this.textContent='✓';setTimeout(()=>this.textContent='📋',1000)">📋</button>
          </div>
          <div class="label"><span class="label-text-alt text-base-content/50">Tavily 失败时的备选</span></div>
        </label>
        <div class="pt-2">
          <button type="submit" class="btn btn-primary w-full">保存 API 配置</button>
        </div>
      </form>
    </div>
  </div>

  <div class="card bg-base-100 shadow mb-6">
    <div class="card-body gap-0">
      <h2 class="card-title text-lg mb-4">EasyClaude Keys</h2>
      <form method="POST" action="/settings" class="space-y-4">
        <input type="hidden" name="action" value="save_easyclaude_keys"/>
        <label class="form-control w-full">
          <div class="label"><span class="label-text font-medium">Key 配置</span></div>
          <textarea name="easyclaude_keys" class="textarea textarea-bordered w-full h-32 font-mono text-sm" placeholder="每行一个，格式：标签 = sk-xxx&#10;主卡 = sk-aaaa...&#10;备用 = sk-bbbb...&#10;sk-cccc...（无标签时自动打码显示）">{{easyclaude_keys_text}}</textarea>
          <div class="label"><span class="label-text-alt text-base-content/50"># 开头为注释，空行忽略。配置后在 <a href="/quota" class="link">额度查询</a> 页面自动加载</span></div>
        </label>
        <div class="pt-2">
          <button type="submit" class="btn btn-primary w-full">保存 EasyClaude Keys</button>
        </div>
      </form>
    </div>
  </div>

  <div class="card bg-base-100 shadow mb-6">
    <div class="card-body gap-0">
      <h2 class="card-title text-lg mb-4">✨ AI 排版（LLM 配置）</h2>
      <form method="POST" action="/settings" class="space-y-4">
        <input type="hidden" name="action" value="save_ai_config"/>
        <label class="form-control w-full">
          <div class="label"><span class="label-text font-medium">API Key</span></div>
          <div class="join w-full">
            <input type="password" name="nullclaw_api_key" id="ai_key_input" value="{{ai_key_value}}" class="input input-bordered join-item w-full" placeholder="sk-..."/>
            <button type="button" class="btn join-item" onclick="const i=document.getElementById('ai_key_input');i.type=i.type==='password'?'text':'password'">👁</button>
          </div>
        </label>
        <label class="form-control w-full">
          <div class="label"><span class="label-text font-medium">Base URL</span></div>
          <input type="text" name="nullclaw_base_url" value="{{ai_base_url_value}}" class="input input-bordered w-full" placeholder="https://api.openai.com/v1"/>
          <div class="label"><span class="label-text-alt text-base-content/50">中转地址，到 /v1 为止</span></div>
        </label>
        <label class="form-control w-full">
          <div class="label"><span class="label-text font-medium">Model</span></div>
          <input type="text" name="nullclaw_model" value="{{ai_model_value}}" class="input input-bordered w-full" placeholder="gpt-4o-mini"/>
          <div class="label"><span class="label-text-alt text-base-content/50">排版器 AI 分析使用的模型</span></div>
        </label>
        <div class="pt-2">
          <button type="submit" class="btn btn-primary w-full">保存 AI 配置</button>
        </div>
      </form>
    </div>
  </div>

  <div class="card bg-base-100 shadow">
    <div class="card-body gap-0">
      <h2 class="card-title text-lg mb-4">修改密码</h2>
      <form method="POST" action="/settings" class="space-y-4">
        <input type="hidden" name="action" value="change_password"/>
        <label class="form-control w-full">
          <div class="label"><span class="label-text font-medium">当前密码</span></div>
          <input type="password" name="current_password" class="input input-bordered w-full" required/>
        </label>
        <label class="form-control w-full">
          <div class="label"><span class="label-text font-medium">新密码</span></div>
          <input type="password" name="new_password" class="input input-bordered w-full" required minlength="6"/>
          <div class="label"><span class="label-text-alt text-base-content/50">至少 6 位</span></div>
        </label>
        <label class="form-control w-full">
          <div class="label"><span class="label-text font-medium">确认新密码</span></div>
          <input type="password" name="confirm_password" class="input input-bordered w-full" required minlength="6"/>
        </label>
        <div class="pt-2">
          <button type="submit" class="btn btn-primary w-full">保存密码</button>
        </div>
      </form>
    </div>
  </div>
</div>
