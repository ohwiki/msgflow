---
import { IMAGE_CDN } from '../consts';

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  fit?: 'cover' | 'contain' | 'scale-down';
}

const { src, alt, width, height, class: className, fit = 'cover' } = Astro.props;

// 完整 URL 直接用，否则拼接 R2 CDN
const fullSrc = src.startsWith('http') ? src : `${IMAGE_CDN}/${src}`;

// 模式切换：环境变量 PUBLIC_IMAGE_RESIZE=true 启用 Worker 裁剪
const enableResize = import.meta.env.PUBLIC_IMAGE_RESIZE === 'true';
const isOwnCdn = !src.startsWith('http');

let optimizedSrc = fullSrc;
if (enableResize && isOwnCdn && width) {
  // Worker 裁剪模式：/resize/w=WIDTH,h=HEIGHT,fit=FIT/PATH
  const params = `w=${width}${height ? `,h=${height}` : ''},fit=${fit},f=auto,q=80`;
  optimizedSrc = `${IMAGE_CDN}/resize/${params}/${src}`;
}
---

<img
  src={optimizedSrc}
  alt={alt}
  width={width}
  height={height}
  loading="lazy"
  decoding="async"
  class={className}
/>
