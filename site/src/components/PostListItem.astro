---
interface Props {
  title: string;
  slug: string;
  date: Date;
  summary?: string;
  tags?: string[];
  basePath?: string;
}

const { title, slug, date, summary, tags = [], basePath = '/articles' } = Astro.props;
---

<article class="mb-8 pb-8 border-b border-border last:border-b-0">
  <a href={`${basePath}/${slug}`} class="group inline-block">
    <h2 class="text-2xl font-semibold text-accent decoration-dashed hover:underline underline-offset-4 focus-visible:no-underline">
      {title}
    </h2>
  </a>
  <div class="mt-2 flex items-center gap-x-2 opacity-80 text-sm">
    <time datetime={date.toISOString().slice(0, 10)}>
      {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
    </time>
  </div>
  {summary && <p class="mt-3 text-foreground">{summary}</p>}
  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <a href={`${basePath.replace('/articles', '/tags')}/${tag}`} class="inline-block text-sm text-accent hover:underline">#{tag}</a>
      ))}
    </div>
  )}
</article>
